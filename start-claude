#!/usr/bin/env bash
set -euo pipefail

DEV_ENV="sudo -E -u dev -H env HOME=/home/dev"

run_as_dev() {
  $DEV_ENV bash -lc "$*"
}

SOCK=/var/run/docker.sock
if [ -S "$SOCK" ]; then
  chown dev "$SOCK" 2>/dev/null || true
fi

# If first arg doesn't start with '-', run it as a command instead of claude
if [ $# -gt 0 ] && [ "${1:0:1}" != "-" ]; then
  exec $DEV_ENV bash -lc "$*"
fi

# Run claude with container plugin and --dangerously-skip-permissions
# Default model can be overridden by --model in args
CLAUDE_CMD="claude --plugin-dir /home/dev/container-plugin --dangerously-skip-permissions"
if [[ "$*" != *"--model"* ]]; then
  CLAUDE_CMD="$CLAUDE_CMD --model us.anthropic.claude-opus-4-6-v1"
fi
exec $DEV_ENV bash -lc "$CLAUDE_CMD $*"
